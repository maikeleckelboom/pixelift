    "happy-dom": "^17.1.2",
    "vite": "^6.1.1",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vitest": "^3.0.6"
  },
  "dependencies": {
    "jpeg-js": "^0.4.4",
    "omggif": "^1.0.10",
    "pngjs": "^7.0.0"
