{
  "name": "pixelift",
  "version": "0.1.0",
  "description": "A modern, universal image processing library that seamlessly extracts pixel data across Node.js and browser environments. Utilizing Sharp on the server and Canvas or WebCodecs API in the browser, it offers a consistent interface for efficient image manipulation and analysis.",
  "author": "Maikel Eckelboom",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "require": "./dist/browser/index.cjs",
      "import": "./dist/browser/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.cjs",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "browser": {
    "sharp": false
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0",
    "bun": ">=1.0.0",
    "sharp": ">=0.34.1"
  },
  "packageManager": "bun@1.2.5",
  "publishConfig": {
    "access": "public"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/maikeleckelboom"
  },
  "scripts": {
    "dev": "vitest --watch",
    "test": "vitest",
    "bench": "vitest --run bench --reporter default",
    "bench:verbose": "vitest --run bench --reporter verbose",
    "test:browser": "vitest --project browser",
    "test:server": "vitest --project server",
    "test:types": "bun scripts/typecheck.ts",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write .",
    "build": "tsup",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "browser",
    "canvas",
    "codecs",
    "decode",
    "extract",
    "image",
    "nodejs",
    "pixels",
    "processing",
    "sharp",
    "ssr",
    "universal",
    "vision",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/pixelift.git"
  },
  "homepage": "https://github.com/maikeleckelboom/pixelift#readme",
  "bugs": {
    "url": "https://github.com/maikeleckelboom/pixelift/issues"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "3.1.2",
    "@types/node": "22.15.3",
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "typescript-eslint": "^8.31.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitest/browser": "^3.1.2",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "type-fest": "^4.40.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.1"
  }
}
