{
  "name": "pixelift",
  "version": "0.1.0",
  "description": "Cross-platform image decoder: convert any image source (URL, file, Blob, HTML element, etc.) into consistent 8-bit RGBA pixel data, with a single lightweight API for browser & Node.js.",
  "author": "Maikel Eckelboom",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "require": "./dist/browser/index.cjs",
      "import": "./dist/browser/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.cjs",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "browser": {
    "sharp": false
  },
  "sideEffects": false,
  "engines": {
    "npm": ">=9.0.0",
    "bun": ">=1.0.0",
    "node" : ">=20.0.0"
  },
  "packageManager": "bun@1.2.5",
  "publishConfig": {
    "access": "public"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/maikeleckelboom"
  },
  "scripts": {
    "dev": "vitest --watch",
    "test": "vitest",
    "test:update": "vitest -u",
    "test:sequential": "vitest run --project=server && vitest run --project=browser && vitest run --project=snapshot-consistency",
    "test:server": "vitest --project server",
    "test:browser": "vitest --project browser",
    "test:consistency": "vitest run test/decode-consistency.test.ts",
    "test:ci": "vitest --reporter dot",
    "bench": "vitest --run bench --reporter verbose",
    "bench:server": "vitest --project server --run bench --reporter verbose",
    "bench:browser": "vitest --project browser --run bench --reporter verbose",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write .",
    "build": "tsup",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "image-decoder",
    "raw-pixels",
    "rgba",
    "cross-platform",
    "browser",
    "nodejs",
    "ssr",
    "webcodecs",
    "offscreen-canvas",
    "sharp",
    "canvas",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/pixelift.git"
  },
  "homepage": "https://github.com/maikeleckelboom/pixelift#readme",
  "bugs": {
    "url": "https://github.com/maikeleckelboom/pixelift/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/browser": "3",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.1"
  }
}
